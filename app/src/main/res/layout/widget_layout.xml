<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:padding="16dp">

    <!-- Container chính chứa text, căn giữa widget -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_tv_word"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wavi"
            android:textColor="#9370DB"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_tv_phonetic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="/ˈwɑːvi/"
            android:textColor="#888888"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/widget_tv_meaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Ứng dụng học tập"
            android:textColor="#2D3142"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Nút Refresh ở góc dưới bên phải -->
    <ImageView
        android:id="@+id/widget_btn_refresh"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:padding="6dp"
        android:src="@drawable/ic_refresh"
        android:contentDescription="Refresh" />

</RelativeLayout>