<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Microphone Check"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Please record your voice to ensure your microphone is working correctly before starting the test."
        android:textSize="16sp"
        android:textColor="#4B5563"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Record Button -->
    <Button
        android:id="@+id/btnRecordTest"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_circle_primary"
        android:text="RECORD"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Press RECORD and say something."
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="32dp"/>

    <!-- Playback Button -->
    <Button
        android:id="@+id/btnPlayTest"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Play Recording"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:enabled="false"
        android:backgroundTint="#10B981"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Start Test Button -->
    <Button
        android:id="@+id/btnStartTest"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Speaking Test"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:enabled="false"
        android:backgroundTint="#4F46E5"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
