<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kiểm tra Microphone"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Để đảm bảo bài thi Speaking được ghi âm tốt nhất, vui lòng nhấn nút bên dưới để ghi âm thử 5 giây. Sau đó hệ thống sẽ tự động phát lại để bạn kiểm tra."
        android:textSize="16sp"
        android:textColor="#666666"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRecordTest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_mic"
        app:backgroundTint="@color/purple_main"
        app:tint="@color/white"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvMicStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nhấn để ghi âm thử"
        android:textSize="16sp"
        android:textColor="@color/purple_main"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Tôi nghe rõ, Bắt đầu thi"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/purple_main"
        android:enabled="false"/>

</LinearLayout>
