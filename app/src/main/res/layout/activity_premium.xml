<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- 1. TOOLBAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="0.5dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nâng cấp Wavi Premium"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center"/>
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 2. NESTED SCROLL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="50dp">


            <!-- SUBSCRIPTION PACKAGES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn gói ưu đãi"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="20dp"
                android:textColor="#333333"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPricePackages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- COMPARISON TABLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quyền lợi Premium"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:textColor="#333333"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header Table -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="Tính năng"
                            android:textStyle="bold"
                            android:textColor="#9E9E9E" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="Free"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:textColor="#9E9E9E" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="Premium"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:textColor="#9370DB" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <!-- Ví dụ dòng 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="Luyện tập part 1, 2, 5"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="#4CAF50" />
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="#9370DB" />

                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="Full 7 part chuyên sâu"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_premiumlock"
                            app:tint="#BDBDBD"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="#9370DB"/>
                    </LinearLayout>
                    <!-- Dòng 3 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="Mẹo và giải thích chi tiết"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_premiumlock"
                            app:tint="#BDBDBD"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="#9370DB"/>
                    </LinearLayout>

                    <!-- Dòng 4 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="Tải đề học offline"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_premiumlock"
                            app:tint="#BDBDBD"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="#9370DB"/>
                    </LinearLayout>

                    <!-- Dòng 5 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="Số lượng đề thi thử"
                            android:textColor="#424242"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="5"
                            android:gravity="center"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="50+"
                            android:gravity="center"
                            android:textColor="#9370DB"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- USER REVIEWS SLIDER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Học viên nói gì về Wavi"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:textColor="#333333"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- FOOTER -->
            <TextView
                android:id="@+id/tvRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:text="Khôi phục thanh toán"
                android:textColor="#9370DB"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="Điều khoản dịch vụ và Chính sách bảo mật"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <View
        android:id="@+id/navDivider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#808080"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@null"
        app:itemTextColor="#000000"
        android:paddingBottom="15dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>