<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Gradient Header Area -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_curved_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include layout="@layout/layout_header_decor" />

    <RelativeLayout
        android:id="@+id/nav_premium"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginTop="45dp"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_chevron"
            android:rotation="180"
            app:tint="#FFFFFF"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_n_ng_c_p_wavi_premium"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/nav_premium"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp"
            android:paddingTop="20dp">

            <!-- SUBSCRIPTION PACKAGES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ch_n_g_i_u_i"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:textColor="#2D3142"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPricePackages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- COMPARISON TABLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_quy_n_l_i_premium"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:textColor="#2D3142"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <!-- Header Table -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="16dp"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/auto_t_nh_n_ng"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#888888" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="@string/auto_free"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#888888" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="@string/auto_pro"
                            android:gravity="center"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/orange_main" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                    <!-- Dòng 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/auto_luy_n_t_p_part_1_2_5"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="#4CAF50" />
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="@color/orange_main" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9" />

                    <!-- Dòng 2 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/auto_full_7_part_chuy_n_s_u"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="20dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_lock"
                            app:tint="#BDBDBD"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="@color/orange_main"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9" />

                    <!-- Dòng 3 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/auto_m_o_v_gi_i_th_ch"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="20dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_lock"
                            app:tint="#BDBDBD"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="@color/orange_main"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9" />

                    <!-- Dòng 4 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/auto_t_i_h_c_offline"
                            android:textColor="#424242"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="20dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_lock"
                            app:tint="#BDBDBD"/>
                        <ImageView
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="0.25"
                            android:src="@drawable/ic_check"
                            app:tint="@color/orange_main"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F9F9F9" />

                    <!-- Dòng 5 -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/auto_thi_th_2"
                            android:textColor="#424242"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="5"
                            android:gravity="center"
                            android:textColor="#888888"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.25"
                            android:text="50+"
                            android:gravity="center"
                            android:textColor="@color/orange_main"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- USER REVIEWS SLIDER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_h_c_vi_n_n_i_g_v_wavi"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:textColor="#2D3142"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- FOOTER -->
            <TextView
                android:id="@+id/tvRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:text="@string/auto_kh_i_ph_c_thanh_to_n"
                android:textColor="@color/purple_main"
                android:textStyle="bold"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="@string/auto_i_u_kho_n_d_ch_v_v_ch_nh_s_ch"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <View
        android:id="@+id/navDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EBEBEB"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="@null"
        app:itemTextColor="#000000"
        android:paddingBottom="15dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>