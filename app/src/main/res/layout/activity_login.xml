<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavi_pastel_purple_gradient"
    tools:context="com.example.waviapp.activities.LoginActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Tiêu đề -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ch_o_m_ng_tr_l_i_wavi"
                android:textColor="#9370DB"
                android:textSize="29sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:layout_marginBottom="48dp" />

            <!-- Email Input -->
            <EditText
                android:id="@+id/edtLoginEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/rounded_input_background"
                android:drawableStart="@drawable/ic_email"
                android:drawablePadding="16dp"
                android:hint="@string/auto_email"
                android:textColor="#2C2C2C"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:importantForAutofill="no"
                android:inputType="textEmailAddress|textNoSuggestions"
                tools:targetApi="o" />

            <!-- Password Input -->
            <EditText
                android:id="@+id/edtLoginPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/rounded_input_background"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="16dp"
                android:hint="@string/auto_m_t_kh_u"
                android:textColor="#2C2C2C"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:importantForAutofill="no"
                android:inputType="textPassword|textNoSuggestions"
                tools:targetApi="o" />

            <!-- Forgot Password -->
            <TextView
                android:id="@+id/txtForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                android:text="@string/auto_qu_n_m_t_kh_u_1"
                android:textColor="#9370DB"
                android:textSize="14.5sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

            <!-- Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/auto_ng_nh_p"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9370DB"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:includeFontPadding="false"
                app:cornerRadius="28dp"
                android:elevation="4dp" />

            <!-- Google Login -->
            <LinearLayout
                android:id="@+id/btnGoogleLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/google_button_background"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_google"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ng_nh_p_v_i_google"
                    android:textColor="#2C2C2C"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Register Link -->
            <TextView
                android:id="@+id/txtRegisterLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="42dp"
                android:text="@string/auto_b_n_ch_a_c_t_i_kho_n_t_o_t_i_k"
                android:textColor="#555555"
                android:textSize="15sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
