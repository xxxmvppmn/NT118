<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/imgAvatarBot"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:src="@drawable/ic_bot_avatar" />

    <TextView
        android:id="@+id/txtMessageBot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/imgAvatarBot"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="60dp"
        android:background="@drawable/bg_bubble_bot"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="Trợ lý AI đang trả lời..."
        android:textColor="#000000"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/txtTimeBot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtMessageBot"
        android:layout_toEndOf="@id/imgAvatarBot"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textColor="#888888"
        android:textSize="11sp"
        android:text="21:15" />
</RelativeLayout>
