<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavi_pastel_purple_gradient"
    tools:context=".activities.OnlineExamResultActivity">

    <include layout="@layout/layout_header_decor" />

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBarResult"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="45dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBackResult"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#9370DB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Kết quả thi"
            android:textColor="#9370DB"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBarResult"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="40dp">

            <!-- Score Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="28dp">

                    <!-- Trophy icon -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆"
                        android:textSize="56sp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Exam name -->
                    <TextView
                        android:id="@+id/tvResultExamTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dragon Quiz Season 1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="20dp"/>

                    <!-- Score circle -->
                    <TextView
                        android:id="@+id/tvResultScore"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:gravity="center"
                        android:text="20/20"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_score_circle"
                        android:layout_marginBottom="16dp"/>

                    <!-- Percent -->
                    <TextView
                        android:id="@+id/tvResultPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#9370DB"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResultMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xuất sắc! Bạn đã hoàn thành!"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="24dp"/>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvResultCorrect"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đúng"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#EEEEEE"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvResultWrong"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#F44336"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sai"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#EEEEEE"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvResultTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12:34"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#FF9800"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thời gian"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rank Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F3E5F5"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏅"
                        android:textSize="32sp"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thứ hạng của bạn"
                            android:textSize="12sp"
                            android:textColor="#7B1FA2"/>

                        <TextView
                            android:id="@+id/tvResultRank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#5 / 51 người thi"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#4A148C"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Leaderboard -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 Bảng xếp hạng"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#9370DB"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <!-- Leaderboard header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="#F3E5F5">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:text="#"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tên"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2"
                            android:layout_marginStart="4dp"/>

                        <TextView
                            android:layout_width="50dp"
                            android:layout_height="wrap_content"
                            android:text="Điểm"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="TG"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7B1FA2"
                            android:gravity="end"/>

                    </LinearLayout>

                    <!-- RecyclerView leaderboard -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLeaderboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nút quay lại -->
            <Button
                android:id="@+id/btnBackToList"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Quay lại danh sách kỳ thi"
                android:textSize="15sp"
                android:backgroundTint="#9370DB"
                android:textColor="#FFFFFF"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
