<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavi_pastel_purple_gradient"
    tools:context="com.example.waviapp.activities.EventInfoActivity">

    <include layout="@layout/layout_header_decor" />

    <RelativeLayout
        android:id="@+id/customTopBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="45dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#9370DB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/auto_t_m_hi_u_th_m_s_ki_n"
            android:textColor="#9370DB"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/customTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#CCFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_h_ng_d_n_s_d_ng_tr_c_khi_tham"
                        android:textColor="#9370DB"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <TextView
                        android:id="@+id/tvPara1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#2D3142"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginBottom="24dp"
                        tools:text="Nội dung đoạn văn 1 sẽ đổ vào đây..."/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0E6FF"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_2_ph_n_th_ng"
                        android:textColor="#9370DB"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_top_1_g_i_premium_3_th_ng_n_t"
                        android:textColor="#9370DB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_n_u_b_n_l_m_th_nh_vi_n_premiu"
                        android:textColor="#FF9800"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:id="@+id/tvPara3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#2D3142"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp"
                        tools:text="Nội dung đoạn văn 3 sẽ đổ vào đây..."/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGotIt"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Đã hiểu"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="#9370DB"
                app:cornerRadius="28dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>