<?xml version="1.0" encoding="utf-8"?>
<!-- Dùng CardView bọc ngoài cùng là cách NHÀN NHẤT để bo góc nguyên cái bảng Dialog -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    android:layout_margin="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <!-- Header: Tiêu đề và nút đóng -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ng_y_sinh"
                android:textColor="#9370DB"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>

            <ImageView
                android:id="@+id/ivClose"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#CCCCCC"/>
        </RelativeLayout>

        <!-- Vùng chọn NumberPicker -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp">

            <NumberPicker
                android:id="@+id/npDay"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="150dp"/>

            <!-- Dấu gạch chéo phân cách cho chuyên nghiệp -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textSize="20sp"
                android:textColor="#9370DB"
                android:layout_marginHorizontal="5dp"/>

            <NumberPicker
                android:id="@+id/npMonth"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="150dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textSize="20sp"
                android:textColor="#9370DB"
                android:layout_marginHorizontal="5dp"/>

            <NumberPicker
                android:id="@+id/npYear"
                android:layout_width="0dp"
                android:layout_weight="1.2"
                android:layout_height="150dp"/>
        </LinearLayout>

        <!-- Nút OK: Dùng MaterialButton để app:cornerRadius hoạt động chuẩn -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/auto_ok"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#9370DB"
            app:cornerRadius="28dp"
            android:textAllCaps="false"
            app:elevation="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>