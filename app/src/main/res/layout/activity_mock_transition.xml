<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F9FAFB"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_write"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Writing Icon"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Speaking Test Completed!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#10B981"
        android:layout_marginBottom="24dp"/>
        
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TOEIC Writing Test"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This section consists of 8 questions.\n\n- Part 1: Write a sentence based on a picture (5 questions).\n- Part 2: Respond to a written request (2 questions).\n- Part 3: Write an opinion essay (1 question).\n- Please manage your time carefully. You can skip to the next question if you finish early."
        android:textSize="16sp"
        android:textColor="#4B5563"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="32dp"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btnStartWriting"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Writing Test"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:backgroundTint="#4F46E5"
        android:textColor="@android:color/white"
        android:layout_marginBottom="24dp"/>

</LinearLayout>
