<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavi_pastel_purple_gradient">

    <include layout="@layout/layout_header_decor" />

    <RelativeLayout
        android:id="@+id/toolbarSettings"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cài đặt"
            android:textColor="#9370DB"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarSettings"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#CCFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginEnd="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivAvatarSettings"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="2dp"
                            app:strokeColor="#FFFFFF"
                            app:strokeWidth="2dp"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                            android:background="#E0E0E0"/>

                        <TextView
                            android:id="@+id/tvAvatarText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="#9370DB"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phạm Minh Ngân"
                            android:textColor="#2D3142"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvPremiumStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thành viên miễn phí"
                            android:textColor="#9370DB"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLogout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng xuất"
                        android:textColor="#FF5252"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground"
                        android:padding="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tài khoản"
                android:textColor="#9370DB"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#CCFFFFFF"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout android:id="@+id/llEditProfile" style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle" android:src="@android:drawable/ic_menu_edit" app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle" android:text="Chỉnh sửa hồ sơ" android:layout_weight="1" android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron" android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ứng dụng"
                android:textColor="#9370DB"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#CCFFFFFF"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout android:id="@+id/llLanguage" style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle" android:text="Ngôn ngữ ứng dụng" android:layout_weight="1" android:textColor="#2D3142"/>
                        <TextView android:id="@+id/tvSelectedLanguage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiếng Việt" android:textColor="#9370DB" android:textSize="14sp" android:layout_marginEnd="8dp" android:textStyle="bold"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron" android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0E6FF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/llDisplay" style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle" android:src="@android:drawable/ic_menu_view" app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle" android:text="Hiển thị" android:layout_weight="1" android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron" android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0E6FF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/llDownloads" style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle" android:src="@android:drawable/ic_menu_save" app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle" android:text="Quản lý tải xuống" android:layout_weight="1" android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron" android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0E6FF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/llReminder" style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle" android:src="@android:drawable/ic_menu_recent_history" app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle" android:text="Nhắc nhở học tập" android:layout_weight="1" android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron" android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hỗ trợ &amp; Kết nối"
                android:textColor="#9370DB"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#CCFFFFFF"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout android:id="@+id/llCommunity" style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle"
                            android:text="Tham gia cộng đồng Wavi"
                            android:layout_weight="1"
                            android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron"
                            android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0E6FF"
                        android:layout_marginHorizontal="16dp"/>

                    <LinearLayout
                        android:id="@+id/llShare"
                        style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle"
                            android:text="Chia sẻ ứng dụng"
                            android:layout_weight="1"
                            android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp"
                            android:layout_height="20dp" android:src="@drawable/ic_chevron"
                            android:rotation="180" app:tint="#9370DB"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0E6FF" android:layout_marginHorizontal="16dp"/>

                    <LinearLayout android:id="@+id/llFeedback"
                        style="@style/SettingItemStyle">
                        <ImageView style="@style/SettingIconStyle"
                            android:src="@android:drawable/ic_menu_send"
                            app:tint="#9370DB"/>
                        <TextView style="@style/SettingTextStyle"
                            android:text="Phản hồi &amp; Hỗ trợ"
                            android:layout_weight="1"
                            android:textColor="#2D3142"/>
                        <ImageView android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron"
                            android:rotation="180"
                            app:tint="#9370DB"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingBottom="12dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>