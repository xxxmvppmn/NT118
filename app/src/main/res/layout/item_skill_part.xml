<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvPartTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ph_n_1_c_v_n_b_n"
            android:textColor="@color/text_dark_gray"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="32dp"/>

        <TextView
            android:id="@+id/tvPartStat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_s_c_u_l_m_0"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_below="@id/tvPartTitle"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:id="@+id/llPartProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_below="@id/tvPartStat"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ho_n_th_nh_4"
                android:textColor="#555555"
                android:textSize="14sp"
                android:layout_marginEnd="12dp"/>

            <ProgressBar
                android:id="@+id/pbPartProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/purple_main"
                android:progressBackgroundTint="#E0E0E0"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivPartLock"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/tvPartTitle"
            android:src="@drawable/ic_lock"
            app:tint="@color/purple_main"
            android:visibility="gone"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
