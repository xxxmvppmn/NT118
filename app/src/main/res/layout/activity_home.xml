<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wavi_pastel_purple_gradient"
    tools:context="com.example.waviapp.activities.HomeActivity">



    <!-- Include Header Decor -->
    <include layout="@layout/layout_header_decor" />

    <!-- Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbarHome"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="24dp"
        android:background="#9370DB"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatarHome"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="2dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" /> <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chào Ngân"
                android:textColor="#E1D5FF"
                android:textSize="25dp" />


        </LinearLayout>
        </LinearLayout>
        <!-- Streak -->
        <LinearLayout
            android:id="@+id/llStreak"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_toStartOf="@id/layoutNotification"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:paddingHorizontal="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/bg_streak_container">

            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:src="@drawable/ic_fire" />

            <TextView
                android:id="@+id/tvStreakCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="12"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Notification -->
        <FrameLayout
            android:id="@+id/layoutNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:padding="8dp">

            <ImageView
                android:id="@+id/icNotification"
                android:layout_width="29dp"
                android:layout_height="29dp"
                android:src="@drawable/ic_notification"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvNotificationCount"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-3dp"
                android:layout_marginEnd="-3dp"
                android:background="@drawable/bg_notification_badge"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarHome"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="50dp">

            <!-- Daily Motivational Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="115dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/wavi_background"
                        android:scaleType="centerCrop"
                        android:alpha="0.78"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#28000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_ch_o_b_n_h_m_nay_ch_ng_ta_h_c"
                        android:textColor="#FFFFFF"
                        android:textSize="19.5sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_centerInParent="true"
                        android:paddingHorizontal="26dp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Progress Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="142dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:baselineAligned="false">

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progressStudy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:progress="65"
                            app:indicatorColor="#9370DB"
                            app:indicatorSize="84dp"
                            app:trackColor="#F0E6FF"
                            app:trackThickness="9dp" />

                        <TextView
                            android:id="@+id/tvProgressPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="65%"
                            android:textColor="#2C2C2C"
                            android:textSize="19sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="12dp"
                        android:background="#EDE4FF" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.7"
                        android:orientation="vertical"
                        android:paddingStart="18dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_m_c_ti_u_toeic"
                            android:textColor="#9E9E9E"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTargetScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_t_800"
                            android:textColor="#9370DB"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_t_v_ng"
                                    android:textColor="#9E9E9E"
                                    android:textSize="12.5sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="650"
                                    android:textColor="#2C2C2C"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_c_n_n"
                                    android:textColor="#9E9E9E"
                                    android:textSize="12.5sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_14_l_i"
                                    android:textColor="#FF6B6B"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Luyện tập kỹ năng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_luy_n_t_p_k_n_ng"
                android:textStyle="bold"
                android:textSize="21sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="16dp"
                android:textColor="#2C2C2C"/>

            <!-- Grid 4 kỹ năng -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:id="@+id/llNghe"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="@color/bg_listen"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_listen" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_nghe"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:textColor="#6B5B8E"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llDoc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="@color/bg_read"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_read" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_c"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:textColor="#6B5B8E"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llNoi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="@color/bg_speak"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_speak" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_n_i"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:textColor="#6B5B8E"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llViet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        app:cardCornerRadius="22dp"
                        app:cardBackgroundColor="@color/bg_write"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_write" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_vi_t"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:textColor="#6B5B8E"/>
                </LinearLayout>
            </GridLayout>

            <!-- Gợi ý chức năng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_g_c_th_s_c"
                android:textStyle="bold"
                android:textSize="21sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="16dp"
                android:textColor="#2C2C2C"/>

            <!-- Grid 3 cột -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:layout_marginHorizontal="16dp">

                <LinearLayout
                    android:id="@+id/llThiOnline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="@color/bg_online_test"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_online_test" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_thi_online"
                        android:textSize="15sp"
                        android:layout_marginTop="12dp"
                        android:textColor="#2C2C2C"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llThiThu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="@color/bg_ets"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_test" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_thi_th"
                        android:textSize="15sp"
                        android:layout_marginTop="12dp"
                        android:textColor="#2C2C2C"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llLyThuyet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        app:cardCornerRadius="24dp"
                        app:cardBackgroundColor="@color/bg_theory"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_theory" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_l_thuy_t"
                        android:textSize="15sp"
                        android:layout_marginTop="12dp"
                        android:textColor="#2C2C2C"
                        android:textStyle="bold"/>
                </LinearLayout>
            </GridLayout>

            <!-- Phần Sổ tay từ vựng và Luyện tập -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F0F0F0"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/tvTabPractice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Luyện tập"
                                android:textColor="#9370DB"
                                android:textStyle="bold"
                                android:textSize="16sp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="15dp"
                                android:layout_marginHorizontal="20dp"
                                android:background="#DDDDDD" />

                            <TextView
                                android:id="@+id/tvTabExam"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thi"
                                android:textColor="#AAAAAA"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tvHistoryStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bạn chưa thực hiện bài luyện tập nào!"
                                android:textColor="#888888"
                                android:textSize="13sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStartNow"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Bắt đầu nào"
                                android:textAllCaps="false"
                                app:cornerRadius="20dp"
                                app:backgroundTint="#9370DB" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F0F0F0"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_notebook_vocab" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Sổ tay từ vựng"
                                android:textColor="#2C2C2C"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvVocabCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#000000"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReviewVocab"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="35dp"
                                android:layout_marginTop="2dp"
                                android:text="Ôn tập"
                                android:textSize="12sp"
                                android:padding="0dp"
                                app:cornerRadius="15dp"
                                app:strokeColor="#9370DB"
                                android:textColor="#9370DB"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Divider -->
    <View
        android:id="@+id/navDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0D9FF"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        android:background="#FFFFFF"
        android:paddingBottom="12dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>