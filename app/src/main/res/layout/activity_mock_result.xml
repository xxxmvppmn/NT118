<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="24dp">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:indeterminateTint="@color/purple_main"
        android:layout_marginBottom="24dp"/>

    <ImageView
        android:id="@+id/ivSuccess"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_check"
        android:visibility="gone"
        app:tint="#4CAF50"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đang tải dữ liệu bài làm của bạn lên máy chủ...\nVui lòng không đóng ứng dụng."
        android:textSize="18sp"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đã tải lên 0/11 file ghi âm"
        android:textSize="14sp"
        android:textAlignment="center"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHome"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Trở về Trang chủ"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/purple_main"
        android:visibility="gone"/>

</LinearLayout>
