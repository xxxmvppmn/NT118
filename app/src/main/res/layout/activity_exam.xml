<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Gradient Header Area -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="125dp"
        android:background="@drawable/bg_curved_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvExamTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Góc Thi Thử"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="30dp">

            <!-- Section 1: Fulltest -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/tvSeeMore1"
                    android:layout_marginEnd="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOEIC Listening &amp; Reading"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textAllCaps="true"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fulltest | 50"
                        android:textColor="@color/text_dark_gray"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                    
                <TextView
                    android:id="@+id/tvSeeMore1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XEM THÊM"
                    android:textColor="@color/purple_main"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:clipToPadding="false"
                android:layout_marginBottom="32dp">
                
                <LinearLayout
                    android:id="@+id/llFulltest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>


            <!-- Section 2: Minitest -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/tvSeeMore2"
                    android:layout_marginEnd="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOEIC Listening &amp; Reading"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textAllCaps="true"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minitest | 55"
                        android:textColor="@color/text_dark_gray"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                    
                <TextView
                    android:id="@+id/tvSeeMore2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XEM THÊM"
                    android:textColor="@color/purple_main"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:clipToPadding="false"
                android:layout_marginBottom="32dp">
                
                <LinearLayout
                    android:id="@+id/llMinitest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>


            <!-- Section 3: Speaking & Writing -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/tvSeeMore3"
                    android:layout_marginEnd="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phân tích &amp; Chiến lược"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textAllCaps="true"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Speaking &amp; Writing"
                        android:textColor="@color/text_dark_gray"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                    
                <TextView
                    android:id="@+id/tvSeeMore3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XEM THÊM"
                    android:textColor="@color/purple_main"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:id="@+id/llSpeaking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/navDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EBEBEB"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:itemIconTint="@null"
        app:itemTextColor="#000000"
        android:background="@color/white"
        android:paddingBottom="15dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
